<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin — Porra Mundial 2026</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
  <style>* { font-family: 'Inter', sans-serif; } html,body { background:#080c10; color:#e2e8f0; }</style>
</head>
<body class="min-h-screen flex items-center justify-center px-4">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <div class="w-12 h-12 rounded-xl flex items-center justify-center text-2xl mx-auto mb-3"
           style="background:linear-gradient(135deg,#16a34a,#15803d);">⚽</div>
      <h1 class="text-xl font-bold text-white">Panel de administración</h1>
      <p class="text-sm text-slate-500 mt-1">Porra Mundial 2026</p>
    </div>

    <form method="POST" action="/admin/login"
          class="rounded-2xl border border-white/10 p-6"
          style="background:#0e1318;">
      <label class="block text-xs font-semibold text-slate-400 mb-1.5 uppercase tracking-wider">
        Contraseña
      </label>
      <input type="password" name="password" autofocus required
             class="w-full rounded-lg px-4 py-2.5 text-sm text-white outline-none focus:ring-2 focus:ring-green-500/40"
             style="background:#0b0f14; border:1px solid rgba(255,255,255,0.1);">

      <% if (error) { %>
        <p class="text-red-400 text-xs mt-2"><%= error %></p>
      <% } %>

      <button type="submit"
              class="mt-4 w-full rounded-lg py-2.5 text-sm font-semibold text-white transition-opacity hover:opacity-90"
              style="background:linear-gradient(135deg,#16a34a,#15803d);">
        Entrar
      </button>
    </form>

    <p class="text-center mt-4">
      <a href="/" class="text-xs text-slate-600 hover:text-slate-400">← Volver a la porra</a>
    </p>
  </div>
</body>
</html>
