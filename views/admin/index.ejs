<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin — Porra Mundial 2026</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Inter', sans-serif; box-sizing: border-box; }
    html, body { background: #080c10; color: #e2e8f0; }
    .mono { font-family: 'JetBrains Mono', monospace; }
    input[type="number"] {
      background: #0b0f14;
      border: 1px solid rgba(255,255,255,0.1);
      color: #e2e8f0;
      border-radius: 6px;
      padding: 4px 8px;
      width: 56px;
      text-align: center;
      font-family: 'JetBrains Mono', monospace;
      font-size: 13px;
    }
    input[type="number"]:focus { outline: none; border-color: rgba(34,197,94,0.5); }
    input[type="text"] {
      background: #0b0f14;
      border: 1px solid rgba(255,255,255,0.1);
      color: #e2e8f0;
      border-radius: 6px;
      padding: 6px 12px;
      font-size: 13px;
      flex: 1;
    }
    input[type="text"]:focus { outline: none; border-color: rgba(34,197,94,0.5); }
    select {
      background: #0b0f14;
      border: 1px solid rgba(255,255,255,0.1);
      color: #e2e8f0;
      border-radius: 6px;
      padding: 4px 8px;
      font-size: 12px;
      font-family: 'Inter', sans-serif;
      cursor: pointer;
    }
    select:focus { outline: none; border-color: rgba(34,197,94,0.5); }
    select option { background: #0b0f14; color: #e2e8f0; }
    .status-badge {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 4px;
      font-size: 10px;
      font-weight: 600;
      text-transform: uppercase;
    }
    .status-scheduled { background: rgba(100,116,139,0.2); color: #cbd5e1; }
    .status-live { background: rgba(239,68,68,0.2); color: #f87171; }
    .status-halftime { background: rgba(168,85,247,0.2); color: #d8b4fe; }
    .status-finished { background: rgba(34,197,94,0.2); color: #86efac; }
    .btn {
      background: #1a2a1a;
      border: 1px solid rgba(34,197,94,0.2);
      color: #4ade80;
      border-radius: 6px;
      padding: 4px 12px;
      font-size: 11px;
      font-weight: 600;
      cursor: pointer;
      transition: background .15s;
    }
    .btn:hover { background: #1e3a1e; }
    .btn-primary {
      background: linear-gradient(135deg,#16a34a,#15803d);
      border: none;
      color: white;
      padding: 8px 20px;
      font-size: 13px;
      border-radius: 8px;
      font-weight: 600;
      cursor: pointer;
    }
    .btn-danger {
      background: #1a0a0a;
      border: 1px solid rgba(239,68,68,0.2);
      color: #f87171;
      padding: 4px 10px;
      font-size: 11px;
      border-radius: 6px;
      cursor: pointer;
    }
    .section { background: #0e1318; border: 1px solid rgba(255,255,255,0.06); border-radius: 12px; }
    .row-match { border-top: 1px solid rgba(255,255,255,0.04); }
    .row-match:hover { background: rgba(255,255,255,0.015); }
    .has-result { background: rgba(34,197,94,0.05); }
    ::-webkit-scrollbar { width: 4px; height: 4px; }
    ::-webkit-scrollbar-thumb { background: #1e2d3d; border-radius: 3px; }
    /* Ocultar flechas del input number */
    input[type=number]::-webkit-inner-spin-button,
    input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; }
    input[type=number] { -moz-appearance: textfield; }
  </style>
</head>
<body class="min-h-screen">

  <!-- CABECERA -->
  <header style="background:#0b0f14; border-bottom:1px solid rgba(255,255,255,0.06);">
    <div class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-lg flex items-center justify-center text-base shrink-0"
             style="background:linear-gradient(135deg,#16a34a,#15803d);">⚽</div>
        <div>
          <h1 class="text-sm font-bold text-white leading-tight">Panel de administración</h1>
          <p class="text-[10px] text-slate-500">Porra Mundial 2026</p>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <a href="/" class="text-xs text-slate-500 hover:text-slate-300">← Ver porra</a>
        <form method="POST" action="/admin/logout" style="margin:0;">
          <button type="submit" class="btn-danger text-xs px-3 py-1.5 rounded-md">Cerrar sesión</button>
        </form>
      </div>
    </div>
  </header>

  <main class="max-w-5xl mx-auto px-4 py-6 space-y-8">

    <% if (saved) { %>
      <div class="rounded-lg px-4 py-2.5 text-sm text-green-400 flex items-center gap-2"
           style="background:rgba(34,197,94,0.08); border:1px solid rgba(34,197,94,0.2);">
        ✓ Guardado correctamente
      </div>
    <% } %>

    <!-- ═══ PARTICIPANTES ═══════════════════════════════════════════════════ -->
    <section class="section p-5">
      <h2 class="text-xs font-bold uppercase tracking-widest text-slate-500 mb-4">Participantes</h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mb-4">
        <% participants.forEach(p => { %>
          <div class="flex items-center justify-between gap-2 rounded-lg px-3 py-2"
               style="background:#0b0f14; border:1px solid rgba(255,255,255,0.06);">
            <span class="text-sm text-white font-medium"><%= p.name %></span>
            <a href="/admin/participant/<%= p.id %>/predictions"
               class="btn text-[11px] shrink-0">
              Editar pronósticos
            </a>
          </div>
        <% }); %>
      </div>

      <form method="POST" action="/admin/participant/add" class="flex items-center gap-2 pt-3"
            style="border-top:1px solid rgba(255,255,255,0.06);">
        <input type="text" name="name" placeholder="Nombre del nuevo participante" required>
        <button type="submit" class="btn shrink-0">+ Añadir</button>
      </form>
    </section>

    <!-- ═══ CREAR PARTIDO ══════════════════════════════════════════════════════ -->
    <div style="display: flex; gap: 12px;">
      <a href="/admin/create-match" class="btn-primary" style="text-decoration: none; display: inline-block; padding: 10px 20px;">
        + Crear Partido
      </a>
    </div>

    <!-- ═══ RESULTADOS ═══════════════════════════════════════════════════════ -->
    <section class="section overflow-hidden">
      <div class="px-5 pt-5 pb-3">
        <h2 class="text-xs font-bold uppercase tracking-widest text-slate-500">
          Resultados de partidos
        </h2>
        <p class="text-[11px] text-slate-600 mt-0.5">
          Deja los campos vacíos para borrar un resultado. Guarda partido a partido.
        </p>
      </div>

      <%
        let lastGroup = null;
        matches.forEach(match => {
          const hasResult = match.homeScore !== null;
      %>

        <% if (match.group !== lastGroup) { lastGroup = match.group; %>
          <div class="px-5 py-1.5 text-[10px] font-bold uppercase tracking-widest text-slate-600"
               style="background:#0a0d11; border-top:1px solid rgba(255,255,255,0.04);">
            Grupo <%= match.group %>
          </div>
        <% } %>

        <div class="row-match <%= hasResult ? 'has-result' : '' %> px-5 py-2.5" id="match-<%= match.id %>">
          <div class="flex items-center gap-3 flex-wrap">

            <!-- RESULTADOS -->
            <form method="POST" action="/admin/match/<%= match.id %>/result"
                  class="flex items-center gap-3 flex-1">
              <span class="mono text-[10px] text-slate-600 w-8 shrink-0">#<%= match.matchNumber %></span>
              <div class="flex items-center gap-1.5 flex-1 min-w-0">
                <span class="text-sm text-slate-300 truncate" style="min-width:100px;max-width:140px;">
                  <%= match.homeTeam %>
                </span>
                <input type="number" name="homeScore" min="0" max="99"
                       value="<%= hasResult ? match.homeScore : '' %>"
                       placeholder="–">
                <span class="text-slate-600 font-bold mono">–</span>
                <input type="number" name="awayScore" min="0" max="99"
                       value="<%= hasResult ? match.awayScore : '' %>"
                       placeholder="–">
                <span class="text-sm text-slate-300 truncate" style="min-width:100px;max-width:140px;">
                  <%= match.awayTeam %>
                </span>
              </div>
              <button type="submit" class="btn shrink-0">Guardar resultado</button>
            </form>

            <!-- STATUS -->
            <form method="POST" action="/admin/match/<%= match.id %>/status"
                  class="flex items-center gap-2">
              <select name="status" onchange="this.form.submit();">
                <option value="scheduled" <%= match.status === 'scheduled' ? 'selected' : '' %>>Programado</option>
                <option value="live" <%= match.status === 'live' ? 'selected' : '' %>>En directo</option>
                <option value="halftime" <%= match.status === 'halftime' ? 'selected' : '' %>>Descanso</option>
                <option value="finished" <%= match.status === 'finished' ? 'selected' : '' %>>Finalizado</option>
              </select>
            </form>

          </div>
        </div>

      <% }); %>
    </section>

  </main>
</body>
</html>
