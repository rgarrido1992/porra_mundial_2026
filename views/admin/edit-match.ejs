<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Editar Partido — Admin Porra Mundial 2026</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Inter', sans-serif; box-sizing: border-box; }
    html, body { background: #080c10; color: #e2e8f0; }
    input, select, textarea {
      background: #0b0f14;
      border: 1px solid rgba(255,255,255,0.1);
      color: #e2e8f0;
      border-radius: 6px;
      padding: 10px 12px;
      font-size: 13px;
    }
    input:focus, select:focus { outline: none; border-color: rgba(34,197,94,0.5); }
    select option { background: #0b0f14; color: #e2e8f0; }
    .btn-primary {
      background: linear-gradient(135deg,#16a34a,#15803d);
      border: none;
      color: white;
      padding: 10px 20px;
      font-size: 13px;
      border-radius: 8px;
      font-weight: 600;
      cursor: pointer;
    }
    .btn-secondary {
      background: #1a2a1a;
      border: 1px solid rgba(34,197,94,0.2);
      color: #4ade80;
      border-radius: 6px;
      padding: 10px 20px;
      font-size: 13px;
      cursor: pointer;
    }
    .section { background: #0e1318; border: 1px solid rgba(255,255,255,0.06); border-radius: 12px; padding: 20px; }
    .info-box { background: rgba(59,130,246,0.1); border: 1px solid rgba(59,130,246,0.3); border-radius: 8px; padding: 12px; margin-bottom: 20px; color: #93c5fd; font-size: 12px; }
  </style>
</head>
<body class="min-h-screen">

  <!-- CABECERA -->
  <header style="background:#0b0f14; border-bottom:1px solid rgba(255,255,255,0.06);">
    <div class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-lg flex items-center justify-center text-base shrink-0"
             style="background:linear-gradient(135deg,#16a34a,#15803d);">⚽</div>
        <div>
          <h1 class="text-sm font-bold text-white leading-tight">Editar Partido</h1>
          <p class="text-[10px] text-slate-500">Porra Mundial 2026</p>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <a href="/admin" class="text-xs text-slate-500 hover:text-slate-300">Volver</a>
      </div>
    </div>
  </header>

  <main class="max-w-2xl mx-auto px-4 py-6">

    <% if (saved) { %>
      <div class="rounded-lg px-4 py-2.5 text-sm text-green-400 flex items-center gap-2 mb-4"
           style="background:rgba(34,197,94,0.08); border:1px solid rgba(34,197,94,0.2);">
        Partido actualizado correctamente
      </div>
    <% } %>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="rounded-lg px-4 py-2.5 text-sm text-red-400 flex items-center gap-2 mb-4"
           style="background:rgba(239,68,68,0.08); border:1px solid rgba(239,68,68,0.2);">
        Error: <%= error === 'campos-requeridos' ? 'Todos los campos son obligatorios' : 'Los equipos no pueden ser iguales' %>
      </div>
    <% } %>

    <div class="info-box">
      ℹ️ Los pronósticos, resultados y puntos se mantienen intactos. Solo puedes modificar la información del partido.
    </div>

    <div class="section">
      <h2 class="text-sm font-bold uppercase tracking-widest text-slate-500 mb-6">Editar Partido #<%= match.matchNumber %></h2>

      <form method="POST" action="/admin/match/<%= match.id %>/edit" class="space-y-4">

        <!-- Información actual -->
        <div style="background: #0a0d11; border: 1px solid rgba(255,255,255,0.06); border-radius: 8px; padding: 12px; margin-bottom: 16px; font-size: 12px;">
          <div style="color: #64748b; margin-bottom: 4px;">Estado actual:</div>
          <div style="color: #e2e8f0;">
            <strong><%= match.homeTeam %></strong> vs <strong><%= match.awayTeam %></strong>
            <% if (match.homeScore !== null) { %>
              — Resultado: <strong><%= match.homeScore %>–<%= match.awayScore %></strong>
            <% } %>
          </div>
        </div>

        <!-- Tipo de Partido -->
        <div>
          <label style="display: block; font-size: 12px; color: #64748b; margin-bottom: 6px; text-transform: uppercase;">Tipo de Partido *</label>
          <select name="stage" required>
            <% stages.forEach(s => { %>
              <option value="<%= s.value %>" <%= match.stage === s.value ? 'selected' : '' %>><%= s.label %></option>
            <% }); %>
          </select>
        </div>

        <!-- Equipo Local -->
        <div>
          <label style="display: block; font-size: 12px; color: #64748b; margin-bottom: 6px; text-transform: uppercase;">Equipo Local *</label>
          <select name="homeTeam" required>
            <% teams.forEach(team => { %>
              <option value="<%= team %>" <%= match.homeTeam === team ? 'selected' : '' %>><%= team %></option>
            <% }); %>
          </select>
        </div>

        <!-- Equipo Visitante -->
        <div>
          <label style="display: block; font-size: 12px; color: #64748b; margin-bottom: 6px; text-transform: uppercase;">Equipo Visitante *</label>
          <select name="awayTeam" required>
            <% teams.forEach(team => { %>
              <option value="<%= team %>" <%= match.awayTeam === team ? 'selected' : '' %>><%= team %></option>
            <% }); %>
          </select>
        </div>

        <!-- Fecha y Hora -->
        <div>
          <label style="display: block; font-size: 12px; color: #64748b; margin-bottom: 6px; text-transform: uppercase;">Fecha y Hora *</label>
          <input type="datetime-local" name="matchDate" value="<%= localDate %>" required>
        </div>

        <!-- Botones -->
        <div style="display: flex; gap: 12px; margin-top: 20px; padding-top: 20px; border-top: 1px solid rgba(255,255,255,0.06);">
          <button type="submit" class="btn-primary">Guardar cambios</button>
          <a href="/admin" class="btn-secondary" style="text-decoration: none; display: inline-block;">Cancelar</a>
        </div>

      </form>
    </div>

  </main>

</body>
</html>
